# ─── Application ──────────────────────────────────────────────────────
APP_NAME=HealthMap
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Database ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=healthmap
DB_USERNAME=healthmap_user
DB_PASSWORD=

# MySQL container vars (read by mysql:8.0 image)
MYSQL_DATABASE=healthmap
MYSQL_USER=healthmap_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ─── Session ──────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Bootstrap Admin (first-time setup) ───────────────────────────────
BOOTSTRAP_ADMIN_USERNAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@healthmap.com
BOOTSTRAP_ADMIN_PASSWORD=

# ─── ML Service ───────────────────────────────────────────────────────
ML_SERVICE_URL=http://healthmap_ml:8000
